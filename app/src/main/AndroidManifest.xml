<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Location (always-on in Red) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Camera/Mic: camera for QR pairing scan, mic for sos audio. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Required to set AudioManager.mode = MODE_IN_COMMUNICATION
         before WebView's getUserMedia. Without this, the setMode
         call silently no-ops and Chromium's AudioRecord open with
         AudioSource.VOICE_COMMUNICATION fails on Android 14+ with
         "Could not start audio source". Upstream simplex-chat has
         this declared too. -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Vibration for notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake lock for background services -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Boot receiver for auto-start -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Doze exemption. Required for the direct per-app "allow background
         activity" dialog (Settings.ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS):
         without this permission declared the system SILENTLY drops that intent
         (startActivity does not even throw), so the onboarding row appeared to
         "lead nowhere". A safety app must survive Doze to deliver panic/sentinel
         alerts in the background — it qualifies for the Play exemption category
         (apps maintaining a persistent connection for real-time messaging). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Storage for backup -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 13+ replaced READ_EXTERNAL_STORAGE with per-type
         media permissions. Aegis reads images, videos and audio
         when the user attaches gallery items or imports WhatsApp /
         Signal backup folders during onboarding. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- Android 14+ partial-media-access prompt. Without this, the
         "Select photos and videos" partial picker breaks on API 34. -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <!-- Bluetooth for smartwatch -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />

    <!-- Sensors for snatch detection -->
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <!-- BiometricPrompt for app-lock fingerprint/face unlock -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- SIM swap detection: TelephonyManager.networkOperatorName +
         simOperator. Optional — feature degrades gracefully if not granted. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Incoming-call full-screen intent. Without this on Android 14+
         our setFullScreenIntent on the call notification falls back to
         heads-up only — the CallScreen never auto-surfaces when the
         phone is locked or backgrounded. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Self-update: install the downloaded APK from the FileProvider. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.INSTALL_PACKAGES"
        tools:ignore="ProtectedPermissions" />
    <!-- Normal permission (auto-granted) introduced in Android 12 that
         lets PackageInstaller.SessionParams.setRequireUserAction(NOT
         _REQUIRED) actually take effect for a regular app. Without
         this, the OS demotes every silent attempt to "needs user
         confirmation", which broadcasts back to InstallSessionReceiver
         and shows the install dialog — which is fine UX but not the
         silent path the update tile promises. -->
    <uses-permission android:name="android.permission.UPDATE_PACKAGES_WITHOUT_USER_ACTION" />

    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:name=".AegisApp"
        android:allowBackup="false"
        android:extractNativeLibs="true"
        android:icon="@mipmap/ic_aegis"
        android:roundIcon="@mipmap/ic_aegis"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:supportsRtl="true"
        android:localeConfig="@xml/locales_config"
        android:theme="@style/Theme.Aegis.Splash"
        tools:targetApi="35">

        <!-- Deception / fake-shutdown activity was DROPPED — an abuser
             could hide the phone from the victim, which is exactly the
             stalker pattern Aegis is supposed to defend against. -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:supportsPictureInPicture="true"
            android:resizeableActivity="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- QR scanner pinned to portrait. zxing's default
             CaptureActivity inherits sensor orientation, which causes
             "camera flips sideways" reports on phones the user is
             tilting while opening the scanner. -->
        <activity
            android:name=".util.PortraitCaptureActivity"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/zxing_CaptureTheme"
            android:windowSoftInputMode="stateAlwaysHidden" />

        <!-- [DEVICE_OWNER] Admin receiver for Red variant -->
        <receiver
            android:name=".admin.AegisAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- Single foreground service. Used to be four — now consolidated
             so the user sees one persistent "shield active" notification
             with a Turn off action, not a notification-shade traffic jam. -->
        <service
            android:name=".services.ProtocolService"
            android:foregroundServiceType="location|dataSync|microphone|camera|specialUse"
            android:exported="false">
            <!-- specialUse subtype (Android 14+): the always-on service
                 runs as specialUse on API 34+ instead of dataSync, because
                 dataSync is capped at ~6h/24h and the system crashes the
                 app on timeout. This declares WHY the persistent FGS
                 exists (also surfaced to Play review). -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Maintains the always-on end-to-end-encrypted messaging connection, location for SOS/safety alerts, and audio/video for encrypted calls." />
        </service>

        <!-- Auto-start on boot -->
        <receiver
            android:name=".receivers.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- MY_PACKAGE_REPLACED fires the moment a self-update
                     swaps in the new APK and Android kills the old
                     process. Without this, the foreground service
                     stays down until the user manually relaunches. -->
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Inline + Android Auto reply / mark-as-read for message
             notifications. exported=false because only our own
             PendingIntents fire these. -->
        <receiver
            android:name=".MessageReplyReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="app.aether.aegis.action.MSG_REPLY" />
                <action android:name="app.aether.aegis.action.MSG_MARK_READ" />
            </intent-filter>
        </receiver>
        <!-- Dismiss action on inbound sos notifications. The
             notification is ongoing+!autoCancel so a stray swipe can't
             clear it; this receiver is the explicit "I've seen it"
             affordance. -->
        <receiver
            android:name=".SOSDismissReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="app.aether.aegis.action.SOS_DISMISS" />
            </intent-filter>
        </receiver>

        <!-- "I'M OK" action on the crash-detection countdown.
             Class-targeted by our own PendingIntent, so no intent-filter
             and not exported. -->
        <receiver
            android:name=".crashdetection.CrashCancelReceiver"
            android:exported="false" />

        <!-- Sender-side "STOP SOS" action on the ongoing sos
             notification that fires on the panicking phone itself.
             Distinct from SOSDismissReceiver (receiver-side). -->
        <receiver
            android:name=".SOSCancelOwnReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="app.aether.aegis.action.SOS_CANCEL_OWN" />
            </intent-filter>
        </receiver>

        <!-- Android Auto: declares that our MessagingStyle notifications
             work in cars. No Google library dep — just a manifest hint
             that lets Auto project our notification + Reply / Mark-read
             actions when the phone is plugged into a head unit. -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <!-- FileProvider exposing downloaded update APK to the system installer -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!-- Home-screen widget -->
        <receiver
            android:name=".widget.AegisWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aegis_widget_info" />
        </receiver>

    </application>

</manifest>
