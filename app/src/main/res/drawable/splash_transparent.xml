<?xml version="1.0" encoding="utf-8"?>
<!-- Fully transparent 1x1 vector used as the system splash's
     animated-icon slot. Android's splash slot enforces an adaptive-
     icon mask (108 dp art inside a 192 dp circle) which crops the
     Aegis hex top and bottom — the artwork looks truncated. We hide
     the system icon entirely so the only thing the user sees during
     the system splash is the cosmic black background; the Compose
     AegisSplashScreen then draws the full, uncropped wordmark + hex
     immediately afterwards. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="1dp"
    android:height="1dp"
    android:viewportWidth="1"
    android:viewportHeight="1">
    <path
        android:fillColor="#00000000"
        android:pathData="M0,0 L1,0 L1,1 L0,1 Z" />
</vector>
